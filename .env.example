# =============================================================================
# LMS Corporativo — Variables de entorno
# Copia este archivo como .env y rellena cada valor antes de levantar el stack
# NUNCA subas el archivo .env a GitHub
# =============================================================================

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
# Genera con: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# True solo en desarrollo local, False siempre en producción
DEBUG=False

# Tu dominio real, separado por comas (sin espacios)
ALLOWED_HOSTS=tudominio.com,www.tudominio.com

# ---------------------------------------------------------------------------
# Base de datos PostgreSQL
# ---------------------------------------------------------------------------
# Variables que usa el servicio "db" del docker-compose
DB_NAME=lms_prod
DB_USER=lms_user
DB_PASSWORD=contraseña_segura_aqui

# URL completa que usa Django (el host es siempre "db" dentro de Docker)
DATABASE_URL=postgres://lms_user:contraseña_segura_aqui@db:5432/lms_prod

# ---------------------------------------------------------------------------
# Redis (broker Celery)
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# CORS — orígenes permitidos para llamadas al API
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# ---------------------------------------------------------------------------
# URLs públicas
# ---------------------------------------------------------------------------
# Usada en links de emails de notificaciones y certificados
FRONTEND_URL=https://tudominio.com

# URL del backend inyectada en el build del frontend
VITE_API_URL=https://tudominio.com

# ---------------------------------------------------------------------------
# Email (SMTP — Microsoft 365 / Office 365)
# ---------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=sistema@tuempresa.com
EMAIL_HOST_PASSWORD=contraseña_email_aqui
DEFAULT_FROM_EMAIL=LMS Cooperativa <sistema@tuempresa.com>

# ---------------------------------------------------------------------------
# Active Directory / LDAP
# Comenta estas variables si no usas sincronización con AD
# ---------------------------------------------------------------------------
LDAP_SERVER=ldap://ad-server.tuempresa.com
LDAP_BIND_DN=CN=svc-lms,OU=Servicios,DC=tuempresa,DC=com
LDAP_BIND_PASSWORD=contraseña_ldap_aqui
LDAP_SEARCH_BASE=DC=tuempresa,DC=com
LDAP_USER_SEARCH_FILTER=(sAMAccountName={username})

# ---------------------------------------------------------------------------
# IA — Anthropic API (módulo de generación de contenido con IA)
# Deja vacío si no usas el módulo IA
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-aqui-tu-clave

# ---------------------------------------------------------------------------
# Storage (local = servidor, sharepoint = SharePoint Online)
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local

# ---------------------------------------------------------------------------
# Seguridad (producción)
# Dejar en False cuando Nginx actúa como proxy TLS (configuración estándar)
# ---------------------------------------------------------------------------
SECURE_SSL_REDIRECT=False

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=WARNING
LOG_FORMAT=json
