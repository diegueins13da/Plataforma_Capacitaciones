# =============================================================================
# LMS Corporativo — Variables de entorno
#
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Edita .env con tus valores reales
#   3. NUNCA subas .env a GitHub (ya está en .gitignore)
#
# Admin creado automáticamente al primer arranque:
#   Email:      admin@empresa.com
#   Contraseña: Demo1234!   ← cámbiala en el primer login
#
# ─── MOVER A OTRO SERVIDOR ───────────────────────────────────────────────────
# Solo tienes que cambiar la IP en ESTAS 4 variables (busca "192.168.1.100"):
#   CORS_ALLOWED_ORIGINS, CSRF_TRUSTED_ORIGINS, FRONTEND_URL, VITE_API_URL
# El resto del archivo puede quedarse igual.
# =============================================================================

# Nombre del proyecto Docker (mantén "lms" para consistencia)
COMPOSE_PROJECT_NAME=lms

# ---------------------------------------------------------------------------
# Django — OBLIGATORIO CAMBIAR
# Genera SECRET_KEY con:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
# ---------------------------------------------------------------------------
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria-de-50-caracteres

DEBUG=False

# Sin http:// — solo IP o dominio, separados por coma sin espacios
# Ejemplos: 192.168.1.100,localhost  |  miempresa.com,www.miempresa.com
ALLOWED_HOSTS=192.168.1.100,localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Base de datos PostgreSQL — OBLIGATORIO CAMBIAR DB_PASSWORD
# ---------------------------------------------------------------------------
DB_NAME=lms_prod
DB_USER=lms_user
DB_PASSWORD=cambia-esta-contrasena-segura

# El host "db" es el nombre del servicio dentro de Docker — no lo cambies
DATABASE_URL=postgres://lms_user:cambia-esta-contrasena-segura@db:5432/lms_prod

# ---------------------------------------------------------------------------
# Redis (broker de tareas) — no cambiar
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# URLs públicas — pon la IP o dominio donde estará la plataforma
# LAN sin SSL:    http://192.168.1.100
# Internet HTTPS: https://miempresa.com
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://192.168.1.100
CSRF_TRUSTED_ORIGINS=http://192.168.1.100
FRONTEND_URL=http://192.168.1.100
VITE_API_URL=http://192.168.1.100

# ---------------------------------------------------------------------------
# Seguridad de cookies
# LAN sin SSL (HTTP):      False
# Producción con HTTPS:    True
# ---------------------------------------------------------------------------
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False

# ---------------------------------------------------------------------------
# Email SMTP (opcional)
# Si no lo configuras, los correos de bienvenida y notificaciones no se envían.
# Compatible con Microsoft 365, Gmail, etc.
# ---------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=sistema@tuempresa.com
EMAIL_HOST_PASSWORD=contrasena-del-correo
DEFAULT_FROM_EMAIL=LMS Corporativo <sistema@tuempresa.com>

# ---------------------------------------------------------------------------
# IA — Anthropic Claude (módulo de generación de contenido con IA)
# Obtén tu clave en: https://console.anthropic.com
# Deja vacío para desactivar el módulo IA
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# LDAP / Active Directory (opcional)
# Configura desde el panel de administración una vez dentro de la plataforma
# ---------------------------------------------------------------------------
LDAP_ENABLED=False

# ---------------------------------------------------------------------------
# Storage y logging
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local
LOG_LEVEL=WARNING
LOG_FORMAT=json
